# GitHub
GITHUB_TOKEN=your_github_token
TAB3_DEFAULT_GITHUB_TOKEN=your_tab3_default_github_token

# Auth
NIGHTSHIFT_JWT_SECRET=replace_with_a_strong_secret
NIGHTSHIFT_JWT_EXPIRE_MINUTES=10080
NIGHTSHIFT_LOG_LEVEL=INFO
NIGHTSHIFT_RUNTIME_ROOT=/app/runtime

# GitHub OAuth
NIGHTSHIFT_GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
NIGHTSHIFT_GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret
NIGHTSHIFT_GITHUB_OAUTH_SCOPE=read:user user:email
NIGHTSHIFT_GITHUB_OAUTH_TIMEOUT_SECONDS=15
NIGHTSHIFT_GITHUB_OAUTH_SESSION_TTL_SECONDS=600
# Required when GitHub OAuth is enabled and the callback must not trust request Host headers
NIGHTSHIFT_PUBLIC_BASE_URL=https://your-domain.example
# Optional explicit callback URL override
NIGHTSHIFT_GITHUB_OAUTH_REDIRECT_URI=https://your-domain.example/auth/github/callback

# Generator overrides
NIGHTSHIFT_GENERATOR_API_KEY=your_model_api_key
NIGHTSHIFT_GENERATOR_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
NIGHTSHIFT_GENERATOR_MODEL=glm-4-flash
NIGHTSHIFT_GENERATOR_TEMPERATURE=0.3
NIGHTSHIFT_GENERATOR_TOP_P=0.9
NIGHTSHIFT_GENERATOR_MAX_TOKENS=1200
NIGHTSHIFT_GENERATOR_TIMEOUT_SECONDS=25
NIGHTSHIFT_GENERATOR_MAX_RETRIES=1
NIGHTSHIFT_LLM_MIN_INTERVAL_SECONDS=1.2
NIGHTSHIFT_LLM_RATE_LIMIT_COOLDOWN_SECONDS=8
NIGHTSHIFT_LLM_RATE_LIMIT_RETRIES=2
NIGHTSHIFT_DELIVERY_DEDUP_SECONDS=15
NIGHTSHIFT_DELIVERY_TIMEZONE=Asia/Shanghai
NIGHTSHIFT_DELIVERY_POLL_SECONDS=30
NIGHTSHIFT_DELIVERY_SCHEDULER_ENABLED=true
NIGHTSHIFT_EMAIL_REPORT_CACHE_TTL_MINUTES=180
NIGHTSHIFT_ALLOWED_LLM_HOSTS=open.bigmodel.cn
NIGHTSHIFT_ALLOWED_EMAIL_ENDPOINTS=dm.aliyuncs.com
NIGHTSHIFT_PROXY_ALLOWED_HOSTS=github.com,raw.githubusercontent.com,codeload.github.com

# Embedder overrides
NIGHTSHIFT_EMBEDDER_API_KEY=your_model_api_key
NIGHTSHIFT_EMBEDDER_BASE_URL=https://api.siliconflow.cn/v1
NIGHTSHIFT_EMBEDDER_MODEL=BAAI/bge-large-zh-v1.5
NIGHTSHIFT_EMBEDDER_DIMENSION=1024

# Alibaba Cloud Direct Mail
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_CLOUD_DM_ACCOUNT_NAME=notice@example.com
ALIBABA_CLOUD_DM_REGION_ID=cn-hangzhou
ALIBABA_CLOUD_DM_ENDPOINT=dm.aliyuncs.com
ALIBABA_CLOUD_DM_ADDRESS_TYPE=1
ALIBABA_CLOUD_DM_REPLY_TO_ADDRESS=false
ALIBABA_CLOUD_DM_FROM_ALIAS=NightShift
ALIBABA_CLOUD_DM_CONNECT_TIMEOUT_MS=5000
ALIBABA_CLOUD_DM_READ_TIMEOUT_MS=10000

# Feature flags
NIGHTSHIFT_FEATURE_CODE_PANORAMA=true
NIGHTSHIFT_FEATURE_SUBSCRIPTIONS=true
