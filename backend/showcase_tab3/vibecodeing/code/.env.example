# Unified provider selector. Supported values:
# deepseek, openai, anthropic, gemini, openrouter, ollama, compatible
AI_PROVIDER=""
AI_API_KEY=""
AI_BASE_URL=""
AI_MODEL=""
AI_REVIEW_MODEL=""

# DeepSeek OpenAI-compatible Chat Completions configuration
# Do not commit real secrets. Put your actual values in .env.local instead.
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_REVIEW_MODEL="deepseek-chat"

# Optional backward-compatible aliases if you still want to use the old variable names.
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL=""
OPENAI_REVIEW_MODEL=""
OPENAI_REASONING_EFFORT=""
OPENAI_DISABLE_RESPONSE_STORAGE=""

# Anthropic official Messages API
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_MODEL=""
ANTHROPIC_REVIEW_MODEL=""

# Google Gemini official generateContent API
GEMINI_API_KEY=""
GOOGLE_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
GEMINI_MODEL=""
GEMINI_REVIEW_MODEL=""

# Other common OpenAI-compatible vendors
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL=""
OPENROUTER_REVIEW_MODEL=""
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL=""

FUNCTION_ANALYSIS_MAX_DEPTH="2"
KEY_SUB_FUNCTION_LIMIT="10"
GITHUB_TOKEN=""

# Embedded Tab3 runtime defaults. Usually keep these in .env.tab3.
SHOWCASE_PUBLIC_BASE="/"
SHOWCASE_OUT_DIR="dist"
TAB3_EMBEDDED=""
TAB3_DISABLE_LOCAL_PROJECT=""
TAB3_DEFAULT_GITHUB_TOKEN=""

# Optional app URL used by some deployment environments.
APP_URL="MY_APP_URL"
